# App
APP_NAME=GRDados
APP_ENV=development
SECRET_KEY=django-insecure-change-me
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Backend
DJANGO_SETTINGS_MODULE=config.settings
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database
POSTGRES_DB=grdados
POSTGRES_USER=grdados
POSTGRES_PASSWORD=grdados
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://grdados:grdados@db:5432/grdados

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
